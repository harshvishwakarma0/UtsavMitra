rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superAdmin';
    }

    function isEventMember(eventId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/events/$(eventId)) &&
        (
          request.auth.uid in get(/databases/$(database)/documents/events/$(eventId)).data.memberUids ||
          request.auth.uid == get(/databases/$(database)/documents/events/$(eventId)).data.createdBy
        );
    }

    function isEventOwner(eventId) {
      return isEventMember(eventId) && (
        get(/databases/$(database)/documents/events/$(eventId)).data.createdBy == request.auth.uid ||
        isSuperAdmin()
      );
    }

    function isReasonableSize() {
      return request.resource == null || request.resource.data.keys().size() < 50;
    }

    // Users: super admin full; users read/update own doc only.
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow create: if isSuperAdmin() || (request.auth.uid == uid && !exists(/databases/$(database)/documents/users/$(uid)));
      allow update: if isSuperAdmin() || (request.auth.uid == uid);
      allow delete: if isSuperAdmin();
    }

    // Events: members read; owner or super admin write.
    match /events/{eventId} {
      allow read: if isEventMember(eventId) || isSuperAdmin();
      allow create: if isSuperAdmin() || (
        isSignedIn() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.memberUids.hasAll([request.auth.uid]) &&
        isReasonableSize()
      );
      allow update: if isEventOwner(eventId) || isSuperAdmin();
      allow delete: if isEventOwner(eventId) || isSuperAdmin();

      match /{subcollection}/{docId} {
        allow read: if isEventMember(eventId) || isSuperAdmin();
        allow create, update: if (isEventMember(eventId) || isSuperAdmin()) && isReasonableSize();
        allow delete: if isEventMember(eventId) || isSuperAdmin();
      }
    }

    // Shared templates: all signed-in read; creator writes own; super admin manages all.
    match /templates/{tid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isReasonableSize();
      allow update, delete: if isSuperAdmin() ||
        (isSignedIn() && resource.data.ownerUid == request.auth.uid);
    }
  }
}
